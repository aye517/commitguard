{
  "name": "commitguard",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.14.2",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "clean": "turbo run clean",
    "init": "easytest init",
    "check": "easytest check",
    "generate": "easytest generate",
    "generate:run": "easytest generate --run",
    "generate:all": "easytest generate --all",
    "generate:yes": "easytest generate --yes",
    "test": "vitest run"
  },
  "dependencies": {
    "@commitguard/cli": "workspace:*"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
